#!/bin/sh

set -eu

cmoc_root=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
venv_python="$cmoc_root/.venv/bin/python"

if [ ! -x "$venv_python" ]; then
    {
        printf '%s\n' "cmoc requires $venv_python."
        printf '%s\n' "Create the virtual environment and install cmoc:"
        printf '%s\n' "  cd \"$cmoc_root\""
        printf '%s\n' "  /usr/bin/python3 -m venv .venv"
        printf '%s\n' "  ./.venv/bin/python -m pip install -e ."
    } >&2
    exit 1
fi

exec "$venv_python" "$cmoc_root/src/main.py" "$@"
